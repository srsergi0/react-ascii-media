{
  "name": "react-ascii-media",
  "version": "1.1.1",
  "description": "Real-time video & image to full-color RGB ASCII art converter. WebGL-accelerated React components with 60fps performance.",
  "type": "module",
  "main": "dist-lib/index.cjs",
  "module": "dist-lib/index.es.js",
  "types": "dist-lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist-lib/index.d.ts",
        "default": "./dist-lib/index.es.js"
      },
      "require": {
        "types": "./dist-lib/index.d.ts",
        "default": "./dist-lib/index.cjs"
      }
    }
  },
  "sideEffects": ["*.css"],
  "files": [
    "dist-lib"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build --config vite.lib.config.ts",
    "build:demo": "vite build",
    "preview": "vite preview",
    "clean": "if (Test-Path dist) { Remove-Item -Recurse -Force dist }; if (Test-Path dist-lib) { Remove-Item -Recurse -Force dist-lib }",
    "lint": "tsc --noEmit"
  },
  "homepage": "https://srsergi0.github.io/react-ascii-media",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srsergi0/react-ascii-media.git"
  },
  "bugs": {
    "url": "https://github.com/srsergi0/react-ascii-media/issues"
  },
  "keywords": [
    "react",
    "ascii",
    "ascii-art",
    "video",
    "image",
    "converter",
    "webgl",
    "shader",
    "react-component",
    "rgb-ascii",
    "media-to-ascii"
  ],
  "license": "Apache-2.0",
  "author": "",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-dts": "^4.5.3"
  }
}
